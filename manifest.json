{
  "manifest_version": 3,
  "name": "SviBlox Beta",
  "version": "0.5.0",
  "version_name": "0.5.0 beta",
  "description": "BETA. Roblox home, friend stats, badges, store extras, subplaces, themes, currency, total spent, and playtime tracking.",
  "permissions": ["storage", "alarms", "unlimitedStorage"],
  "host_permissions": [
    "https://www.roblox.com/*",
    "https://*.roblox.com/*",
    "https://docs.google.com/spreadsheets/*",
    "https://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.ts",
    "type": "module"
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/*"],
      "js": ["src/content/router.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.roblox.com/*"],
      "js": ["src/content/fiberBridgeMain.ts"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://docs.google.com/spreadsheets/d/17HE0xTN5tuq8BAkwvtP17tlJW8rpFNI3WzbI4LYXchk/*"
      ],
      "js": ["src/content/uhblSheetScraperMain.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://docs.google.com/spreadsheets/d/17HE0xTN5tuq8BAkwvtP17tlJW8rpFNI3WzbI4LYXchk/*"
      ],
      "js": ["src/content/uhblSheetScraperBridge.ts"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    },
    "default_popup": "src/popup/index.html",
    "default_title": "SviBlox"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "public/icons/classicroblox.png",
        "public/icons/uhbl-star-half.png",
        "public/icons/uhbl-star-1.png",
        "public/icons/uhbl-star-2.png",
        "public/icons/uhbl-star-3.png",
        "public/icons/uhbl-star-4.png",
        "public/icons/uhbl-star-5.png",
        "public/icons/uhbl-star-6.png"
      ],
      "matches": ["https://*.roblox.com/*"]
    }
  ]
}
